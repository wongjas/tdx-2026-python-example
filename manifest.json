{
  "_metadata": {
      "major_version": 1,
      "minor_version": 1
  },
  "display_information": {
      "name": "Emoji Reaction Reader"
  },
  "features": {
      "bot_user": {
          "display_name": "Emoji Reaction Reader",
          "always_online": false
      },
      "shortcuts": [
          {
              "name": "Reaction Emails",
              "type": "message",
              "callback_id": "reaction_emails_shortcut",
              "description": "List emails of users who reacted to this message"
          }
      ]
  },
  "oauth_config": {
      "scopes": {
          "bot": [
              "commands",
              "chat:write",
              "users:read",
              "users:read.email"
          ]
      }
  },
  "settings": {
      "interactivity": {
          "is_enabled": true
      },
      "org_deploy_enabled": true,
      "socket_mode_enabled": true,
      "token_rotation_enabled": false
  }
}
